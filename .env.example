PORT=3000

# URL where the React dashboard runs (Vite dev server)
# Example: http://localhost:5174
DASHBOARD_URL=http://localhost:5174

# Base URL that the dashboard (inside Puppeteer) uses to call this API
SCREENSHOT_API_BASE=http://127.0.0.1:3000

# Optional: path to Chrome/Chromium for Puppeteer on Windows
# Uncomment and point to your local Chrome if Puppeteer fails to launch.
# PUPPETEER_EXECUTABLE_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# Frontend: API URL used by the browser when you open the dashboard directly
# Match this to where your backend API is reachable from your machine.
VITE_API_BASE=http://127.0.0.1:3000
